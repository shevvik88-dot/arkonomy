<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#0B1426</item>
        <item name="colorPrimaryDark">#0B1426</item>
        <item name="colorAccent">#38B6FF</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Dark status bar so icons show light on dark background -->
        <item name="android:statusBarColor">#0B1426</item>
        <item name="android:navigationBarColor">#0B1426</item>
        <!-- Edge-to-edge: let web content draw under system bars -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="android:statusBarColor">#0B1426</item>
        <item name="android:navigationBarColor">#0B1426</item>
    </style>
</resources>
